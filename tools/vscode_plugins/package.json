{
  "name": "ason-vscode",
  "displayName": "ASON Language Support",
  "description": "Language support for ASON (Another Structured Object Notation) format — syntax highlighting, formatting, compression, error diagnostics, and field hints",
  "version": "0.1.0",
  "publisher": "ason",
  "repository": {
    "type": "git",
    "url": "https://github.com/ason-lab/ason-go"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters",
    "Linters"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ason",
        "aliases": [
          "ASON",
          "ason"
        ],
        "extensions": [
          ".ason"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "ason",
        "scopeName": "source.ason",
        "path": "./syntaxes/ason.tmLanguage.json"
      },
      {
        "scopeName": "markdown.ason.codeblock",
        "path": "./syntaxes/ason.markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.ason": "ason"
        }
      }
    ],
    "commands": [
      {
        "command": "ason.format",
        "title": "ASON: Format (Beautify)",
        "enablement": "resourceLangId == ason"
      },
      {
        "command": "ason.compress",
        "title": "ASON: Compress (Minify)",
        "enablement": "resourceLangId == ason"
      },
      {
        "command": "ason.toJSON",
        "title": "ASON: Convert to JSON",
        "enablement": "resourceLangId == ason"
      },
      {
        "command": "ason.fromJSON",
        "title": "ASON: Convert JSON to ASON"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "ason.format",
          "when": "resourceLangId == ason",
          "group": "1_modification@1"
        },
        {
          "command": "ason.compress",
          "when": "resourceLangId == ason",
          "group": "1_modification@2"
        },
        {
          "command": "ason.toJSON",
          "when": "resourceLangId == ason",
          "group": "1_modification@3"
        },
        {
          "command": "ason.fromJSON",
          "when": "resourceLangId == json",
          "group": "1_modification@1"
        }
      ]
    },
    "configuration": {
      "title": "ASON",
      "properties": {
        "ason.lspPath": {
          "type": "string",
          "default": "",
          "description": "Path to the ason-lsp binary. If empty, uses bundled or PATH."
        },
        "ason.inlayHints.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show field name hints in data tuples."
        }
      }
    }
  },
  "markdown": {
    "previewScripts": [
      "./preview/ason-preview.js"
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.75.0",
    "@types/node": "^18.0.0",
    "typescript": "^5.3.0",
    "@vscode/vsce": "^2.22.0"
  }
}
