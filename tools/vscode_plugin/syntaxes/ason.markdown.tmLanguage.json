{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "ASON Markdown Injection",
  "scopeName": "markdown.ason.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [
    {
      "include": "#ason-fenced-code-block-backtick"
    },
    {
      "include": "#ason-fenced-code-block-tilde"
    }
  ],
  "repository": {
    "ason-fenced-code-block-backtick": {
      "begin": "(^|\\G)(\\s*)(`{3,})\\s*(?i:(ason))\\s*$",
      "end": "(^|\\G)(\\2|\\s{0,3})(\\3)\\s*$",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.markdown" },
        "4": { "name": "fenced_code.block.language.markdown" }
      },
      "endCaptures": {
        "3": { "name": "punctuation.definition.markdown" }
      },
      "name": "markup.fenced_code.block.markdown",
      "contentName": "meta.embedded.block.ason",
      "patterns": [{ "include": "source.ason" }]
    },
    "ason-fenced-code-block-tilde": {
      "begin": "(^|\\G)(\\s*)(~{3,})\\s*(?i:(ason))\\s*$",
      "end": "(^|\\G)(\\2|\\s{0,3})(\\3)\\s*$",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.markdown" },
        "4": { "name": "fenced_code.block.language.markdown" }
      },
      "endCaptures": {
        "3": { "name": "punctuation.definition.markdown" }
      },
      "name": "markup.fenced_code.block.markdown",
      "contentName": "meta.embedded.block.ason",
      "patterns": [{ "include": "source.ason" }]
    }
  }
}
